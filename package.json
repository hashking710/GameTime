{
  "name": "gametime",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev:bot": "pnpm --filter @gametime/bot dev",
    "dev:collector:pandascore": "pnpm --filter @gametime/collector-pandascore dev",
    "dev:collector:opendota": "pnpm --filter @gametime/collector-opendota dev",
    "dev:collector:sportsdb": "pnpm --filter @gametime/collector-sportsdb dev",
    "dev:collector:odds": "pnpm --filter @gametime/collector-odds dev",
    "dev:reminder": "pnpm --filter @gametime/reminder dev",
    "deploy-commands": "pnpm --filter @gametime/bot deploy-commands",
    "db:generate": "pnpm --filter @gametime/db generate",
    "db:migrate": "pnpm --filter @gametime/db migrate",
    "db:studio": "pnpm --filter @gametime/db studio",
    "typecheck": "pnpm -r run typecheck",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  }
}
