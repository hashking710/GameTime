{
  "name": "@gametime/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "tsc -b --watch",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "seed-aliases": "tsx src/seed-aliases.ts",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gametime/shared": "workspace:*",
    "drizzle-orm": "^0.39.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
